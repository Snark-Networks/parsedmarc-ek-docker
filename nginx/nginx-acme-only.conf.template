# Temporary HTTP-only config used during initial certificate acquisition.
# Replaced by the full HTTPS config once the certificate is obtained.
server {
    listen 80;
    server_name ${KIBANA_HOSTNAME};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 200 'Acquiring TLS certificate, please wait...';
        add_header Content-Type text/plain;
    }
}
