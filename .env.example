# ============================================================
# DMARC Processor - Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Elasticsearch ---
# Strong password for the built-in 'elastic' superuser.
ELASTIC_PASSWORD=change_me_strong_password_here

# Strong password for the internal 'kibana_system' service account.
# Must differ from ELASTIC_PASSWORD.
KIBANA_SYSTEM_PASSWORD=change_me_kibana_system_password_here

# Elasticsearch JVM heap size. Set both min and max to the same value.
# Recommended: half of available RAM, up to 32g.
ES_HEAP_SIZE=2g

# Number of days to retain DMARC report data. Defaults to 365.
DATA_RETENTION_DAYS=365

# Password for the read-only 'kibana_viewer' Kibana user.
# If left empty, the viewer user will not be created.
KIBANA_VIEWER_PASSWORD=

# --- Snapshots ---
# Elasticsearch SLM cron schedule for automatic snapshots (6-field ES cron format).
# Default: daily at 02:00 UTC.
SNAPSHOT_SCHEDULE=0 0 2 * * ?

# Number of days to retain snapshots. Minimum 5 snapshots are always kept.
SNAPSHOT_RETENTION_DAYS=30

# --- Watchtower (optional) ---
# Watchtower automatically pulls updated images for parsedmarc and nginx.
# It is disabled by default. To enable it, add 'watchtower' to COMPOSE_PROFILES.
# Portainer users should use Portainer's built-in GitOps updates instead.
#
# To enable via Docker Compose CLI:
#   COMPOSE_PROFILES=watchtower docker compose up -d
# Or set in this file:
#COMPOSE_PROFILES=watchtower
#
# How often Watchtower checks for image updates, in seconds. Default: 86400 (24h).
WATCHTOWER_INTERVAL=86400

# --- IMAP ---
# Hostname or IP of your IMAP server.
IMAP_HOST=mail.example.com

# Full email address of the dedicated DMARC mailbox.
IMAP_USER=dmarc@example.com

# Password for the IMAP account.
IMAP_PASSWORD=change_me_imap_password_here

# --- MaxMind GeoIP ---
# Free account at https://www.maxmind.com — required for IP geolocation in dashboards.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# --- nginx / Let's Encrypt ---
# Public hostname that Kibana will be served on (must have a DNS A record
# pointing to this server before the stack is started).
KIBANA_HOSTNAME=dmarc.example.com

# Email address for Let's Encrypt registration and expiry notices.
# Not required when NGINX_LOCALHOST_ONLY=true.
CERTBOT_EMAIL=admin@example.com

# Set to 'true' to run nginx in HTTP-only mode and skip Let's Encrypt entirely.
# Useful when this stack sits behind a separate reverse proxy that handles TLS.
NGINX_LOCALHOST_ONLY=false

# Host interface Docker binds the nginx ports to.
# Set to '127.0.0.1' when NGINX_LOCALHOST_ONLY=true so the port is not
# reachable from external networks.  Leave unset to bind on all interfaces.
#NGINX_BIND_ADDR=127.0.0.1

# Host ports Docker exposes for nginx. Defaults to 80 and 443.
# Useful if those ports are already in use on the host.
# NGINX_HTTPS_PORT is not used when NGINX_LOCALHOST_ONLY=true.
#NGINX_HTTP_PORT=80
#NGINX_HTTPS_PORT=443
